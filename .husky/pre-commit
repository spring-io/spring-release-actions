#!/bin/sh
if git diff --cached --name-only | grep -q '^src/'; then
    echo "src/ changed — recompiling dist/..."
    npm run compile --silent
    if ! git diff --quiet dist/; then
        echo ""
        echo "ERROR: dist/ is out of date with src/. Stage the recompiled files and commit again:"
        echo ""
        git diff --name-only dist/ | sed 's/^/  git add /'
        echo ""
        exit 1
    fi
fi
